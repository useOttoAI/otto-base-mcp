    { "path": "/supported-tokens", "method": "GET", "price": "0.001", "class": "read-only", "category": "Portfolio", "params": { "chainId": "id", "search": "symbol" }, "description": "Search tokens by symbol on a chain." },
    { "path": "/hyperliquid-account", "method": "GET", "price": "0.001", "class": "read-only", "category": "Portfolio", "params": { "address": "address" }, "description": "Perpetual futures account info." },
    { "path": "/hyperliquid-market", "method": "GET", "price": "0.001", "class": "read-only", "category": "Portfolio", "params": { "asset": "string" }, "description": "Perpetual market data and funding rates." },
    { "path": "/hl-transaction-history", "method": "GET", "price": "0.001", "class": "read-only", "category": "Portfolio", "params": { "address": "address" }, "description": "Perpetual trading history." },
    { "path": "/yield-farming-active", "method": "GET", "price": "0.001", "class": "read-only", "category": "Portfolio", "params": { "userAddress": "address" }, "description": "Active yield positions." },
    { "path": "/yield-farming-historical", "method": "GET", "price": "0.001", "class": "read-only", "category": "Portfolio", "params": { "userAddress": "address" }, "description": "Historical yield positions." }
  ],
  "autonomy": {
    "summary": "For set-and-forget delegation, Otto autonomy operates a user-owned Safe on Base via a scoped, revocable, expiring session key bounded by an on-chain policy.",
