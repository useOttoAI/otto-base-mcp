    { "path": "/llm-research", "method": "POST", "price": "0.50", "class": "compute", "category": "AI Research", "body": { "prompt": "string (<=180 chars)" }, "description": "AI research assistant with live web search." },
    { "path": "/tx-explainer", "method": "POST", "price": "0.01", "class": "compute", "category": "AI Research", "body": { "txHash": "0x...", "chain": "string" }, "description": "Decode and explain an EVM transaction (11 chains)." },
    { "path": "/generate-meme", "method": "POST", "price": "1.00", "class": "compute", "category": "AI Creative", "body": { "prompt": "string", "model": "gpt-image-2|nano-banana-pro", "aspect_ratio": "string" }, "description": "Multi-model image generation via fal.ai." },
    { "path": "/portfolio", "method": "GET", "price": "0.001", "class": "read-only", "category": "Portfolio", "params": { "userId": "address" }, "description": "Multi-chain token balances." },
